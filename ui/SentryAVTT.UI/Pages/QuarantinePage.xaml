<UserControl x:Class="SentryAVTT.UI.Pages.QuarantinePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="Transparent"
                Padding="28 16 28 12"
                BorderThickness="0 0 0 1"
                BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Quarantine"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Isolated threats — review, restore, or delete"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12 0 0 0" />
                <Button Grid.Column="2"
                        Content="&#xE72E;  Refresh"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12 6"
                        FontSize="12"
                        Click="Refresh_Click" />
            </Grid>
        </Border>

        <DataGrid Grid.Row="1"
                  x:Name="QuarantineGrid"
                  Margin="20"
                  AutoGenerateColumns="False"
                  Background="{StaticResource CardBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  RowBackground="Transparent"
                  AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  RowHeight="36"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.IsDeferredScrollingEnabled="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Threat"
                                    Binding="{Binding ThreatName}"
                                    Width="*" />
                <DataGridTextColumn Header="Original Path"
                                    Binding="{Binding OriginalPath}"
                                    Width="2*" />
                <DataGridTextColumn Header="Quarantined At"
                                    Binding="{Binding QuarantinedAt}"
                                    Width="1.5*" />
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="90" />
                <DataGridTemplateColumn Header="Actions"
                                        Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Content="Restore"
                                        Margin="2 0"
                                        Padding="8 2"
                                        FontSize="11"
                                        Style="{StaticResource SecondaryButton}"
                                        CommandParameter="{Binding Id}"
                                        Click="Restore_Click" />
                                <Button Content="Delete"
                                        Margin="2 0"
                                        Padding="8 2"
                                        FontSize="11"
                                        Foreground="{StaticResource DangerBrush}"
                                        Style="{StaticResource SecondaryButton}"
                                        CommandParameter="{Binding Id}"
                                        Click="Delete_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
