<Window x:Class="SentryAVTT.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SentryAVTT.UI.Converters"
        xmlns:vm="clr-namespace:SentryAVTT.UI.ViewModels"
        xmlns:pages="clr-namespace:SentryAVTT.UI.Pages"
        Title="SentryAVTT"
        Width="1024"
        Height="680"
        MinWidth="800"
        MinHeight="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CaptionHeight="36"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"
                      CornerRadius="8" />
    </WindowChrome.WindowChrome>

    <!-- DataContext set in code-behind to App.Dashboard singleton -->

    <Window.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor" />
        <converters:StatusToTextConverter x:Key="StatusToText" />
        <converters:StatusToGlyphConverter x:Key="StatusToGlyph" />
        <converters:BoolToAdminLabelConverter x:Key="AdminLabel" />

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </Window.Resources>

    <Grid>
        <Border CornerRadius="8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Rectangle x:Name="TitleBar"
                           Height="36"
                           VerticalAlignment="Top"
                           Fill="Transparent"
                           IsHitTestVisible="True"
                           Panel.ZIndex="10" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar -->
                    <Border Grid.Column="0"
                            Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="8 0 0 8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="48" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="48" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="&#xE734;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <StackPanel Grid.Row="1"
                                        VerticalAlignment="Top"
                                        Margin="0 8 0 0">
                                <Button Width="36"
                                        Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTip="Dashboard"
                                        Click="DashboardNav_Click">
                                    <TextBlock Text="&#xE80F;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="18"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" />
                                </Button>
                                <Button Width="36"
                                        Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="0 4 0 0"
                                        ToolTip="Quarantine"
                                        Click="QuarantineNav_Click">
                                    <TextBlock Text="&#xE718;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="18"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" />
                                </Button>
                                <Button Width="36"
                                        Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="0 4 0 0"
                                        ToolTip="Admin Console"
                                        Click="ToggleAdmin_Click">
                                    <TextBlock Text="&#xE713;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" />
                                </Button>
                                <Button Width="36"
                                        Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="0 4 0 0"
                                        ToolTip="About"
                                        Click="AboutNav_Click">
                                    <TextBlock Text="&#xE946;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="18"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Main content area with page switching -->
                    <Grid Grid.Column="1" Margin="0 36 0 0">
                        <!-- Dashboard page -->
                        <ScrollViewer x:Name="DashboardPage"
                                      Padding="28 20 28 20"
                                      Background="Transparent"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <!-- Status Shield -->
                                <Border Background="{StaticResource CardBrush}"
                                        CornerRadius="16"
                                        Padding="32"
                                        Margin="0 0 0 24"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource BorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Column="0"
                                                Grid.RowSpan="2"
                                                Width="80"
                                                Height="80"
                                                CornerRadius="40"
                                                Margin="0 0 24 0"
                                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                Opacity="0.12">
                                        </Border>

                                        <Border Grid.Column="0"
                                                Grid.RowSpan="2"
                                                Width="80"
                                                Height="80"
                                                CornerRadius="40"
                                                Margin="0 0 24 0"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToGlyph}}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="36"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Grid.Row="0"
                                                   Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="0 0 0 4" />

                                        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource CardSubtext}"
                                                       VerticalAlignment="Center"
                                                       Margin="0 0 16 0">
                                                <Run Text="Last scan: " />
                                                <Run Text="{Binding Stats.LastScanTime, StringFormat={}{0:HH:mm:ss}, TargetNullValue='Never'}" />
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource CardSubtext}"
                                                       VerticalAlignment="Center"
                                                       Margin="0 0 16 0"
                                                       Text="|" />
                                            <TextBlock Style="{StaticResource CardSubtext}"
                                                       VerticalAlignment="Center"
                                                       Margin="0 0 16 0">
                                                <Run Text="Signatures: " />
                                                <Run Text="{Binding Stats.SignatureAge}" />
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource CardSubtext}"
                                                       VerticalAlignment="Center"
                                                       Margin="0 0 16 0"
                                                       Text="|" />
                                            <TextBlock Style="{StaticResource CardSubtext}"
                                                       VerticalAlignment="Center">
                                                <Run Text="v" />
                                                <Run Text="{Binding Stats.Version}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Stat Cards -->
                                <Grid Margin="0 0 0 24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource StatCard}"
                                            Margin="0 0 6 0">
                                        <StackPanel>
                                            <TextBlock Text="&#xE8B7;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Margin="0 0 0 8" />
                                            <TextBlock Style="{StaticResource CardTitle}" Text="Files Scanned" />
                                            <TextBlock Style="{StaticResource CardValue}" Text="{Binding Stats.FilesScanned}" />
                                            <TextBlock Style="{StaticResource CardSubtext}" Text="Total since launch" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource StatCard}"
                                            Margin="3 0">
                                        <StackPanel>
                                            <TextBlock Text="&#xE783;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       Foreground="{StaticResource DangerBrush}"
                                                       Margin="0 0 0 8" />
                                            <TextBlock Style="{StaticResource CardTitle}" Text="Threats Blocked" />
                                            <TextBlock Style="{StaticResource CardValue}" Text="{Binding Stats.ThreatsBlocked}" />
                                            <TextBlock Style="{StaticResource CardSubtext}" Text="All threats neutralized" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Style="{StaticResource StatCard}"
                                            Margin="3 0">
                                        <StackPanel>
                                            <TextBlock Text="&#xECC5;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       Margin="0 0 0 8" />
                                            <TextBlock Style="{StaticResource CardTitle}" Text="Processes" />
                                            <TextBlock Style="{StaticResource CardValue}" Text="{Binding Stats.ProcessesWatched}" />
                                            <TextBlock Style="{StaticResource CardSubtext}" Text="Currently monitored" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="3"
                                            Style="{StaticResource StatCard}"
                                            Margin="6 0 0 0">
                                        <StackPanel>
                                            <TextBlock Text="&#xE718;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0 0 0 8" />
                                            <TextBlock Style="{StaticResource CardTitle}" Text="Quarantine" />
                                            <TextBlock Style="{StaticResource CardValue}" Text="{Binding Stats.QuarantineCount}" />
                                            <TextBlock Style="{StaticResource CardSubtext}" Text="Isolated items" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Action Buttons -->
                                <Grid Margin="0 0 0 24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            x:Name="ScanButton"
                                            Click="ScanNow_Click"
                                            Margin="0 0 12 0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                <Setter Property="Content" Value="&#xE768;  Quick Scan" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                        <Setter Property="Content" Value="&#xE769;  Cancel Scan" />
                                                        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource SecondaryButton}"
                                            Content="&#xE72E;  Open Quarantine"
                                            Click="OpenQuarantine_Click" />
                                </Grid>

                                <!-- Admin Console -->
                                <Border x:Name="AdminConsolePanel"
                                        Visibility="Collapsed"
                                        Background="{StaticResource CardBrush}"
                                        CornerRadius="12"
                                        Padding="0"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource BorderBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Padding="20 16"
                                                BorderThickness="0 0 0 1"
                                                BorderBrush="{StaticResource BorderBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Admin Console — Process Scan Log"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="1"
                                                        Content="Clear Log"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="12 4"
                                                        FontSize="12"
                                                        Click="ClearLog_Click" />
                                            </Grid>
                                        </Border>

                                        <DataGrid Grid.Row="1"
                                                  x:Name="ProcessLogGrid"
                                                  Height="280"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.IsDeferredScrollingEnabled="True"
                                                  Background="{StaticResource CardBrush}"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  BorderBrush="{StaticResource BorderBrush}"
                                                  RowBackground="Transparent"
                                                  AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                                                  GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                                                  HeadersVisibility="Column"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserResizeRows="False"
                                                  AutoGenerateColumns="False"
                                                  RowHeight="36">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="PID"
                                                                    Binding="{Binding Pid}"
                                                                    Width="70" />
                                                <DataGridTextColumn Header="Process Name"
                                                                    Binding="{Binding Name}"
                                                                    Width="*" />
                                                <DataGridTextColumn Header="Path"
                                                                    Binding="{Binding Path}"
                                                                    Width="2*" />
                                                <DataGridTextColumn Header="Status"
                                                                    Binding="{Binding Status}"
                                                                    Width="90" />
                                                <DataGridTextColumn Header="Threat Hash"
                                                                    Binding="{Binding ThreatHash}"
                                                                    Width="1.5*" />
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <Border Grid.Row="2"
                                                Padding="20 10"
                                                BorderThickness="0 1 0 0"
                                                BorderBrush="{StaticResource BorderBrush}">
                                            <TextBlock Style="{StaticResource CardSubtext}"
                                                       Text="Updates in real-time during scan" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Quarantine page -->
                        <pages:QuarantinePage x:Name="QuarantinePage"
                                              Visibility="Collapsed" />
                        <!-- About page -->
                        <pages:AboutPage x:Name="AboutPage"
                                         Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
